{
  "name": "services-app",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/main.js",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsc",
    "build:watch": "tsc -w",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "pnpm lint:check --fix",
    "lint:check": "eslint .",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate:openapi": "tsx ./scripts/generate-openapi.ts",
    "generate:openapi:check": "tsx ./scripts/generate-openapi.ts --check"
  },
  "dependencies": {
    "@pagopa/io-core-adapter-fastify": "workspace:^",
    "@pagopa/io-core-domain": "workspace:^",
    "@pagopa/io-core-openapi": "workspace:^",
    "fastify": "catalog:",
    "neverthrow": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "shx": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  }
}
