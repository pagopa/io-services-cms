{
  "name": "@io-services-cms/external-clients",
  "version": "1.11.0",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ]
    }
  },
  "files": [
    "dist",
    "index.js"
  ],
  "scripts": {
    "build": "rm -rf ./dist & tsc",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integrations": "vitest run -c __integrations__/vitest.config.ts",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**\"",
    "lint:fix": "eslint --fix \"src/**\"",
    "generate:api-definitions": "rm -rf ./src/generated/api & gen-api-models --api-spec ./openapi.yaml --out-dir ./src/generated/api --response-decoders",
    "generate:selfcare-api-models": "rm -rf ./src/generated/selfcare && gen-api-models --api-spec ./openapi-selfcare.json --out-dir ./src/generated/selfcare --response-decoders"
  },
  "dependencies": {
    "@azure/arm-apimanagement": "^10.0.0",
    "@azure/identity": "^4.13.0",
    "@io-services-cms/fetch-utils": "workspace:^",
    "@pagopa/io-functions-commons": "catalog:",
    "@pagopa/ts-commons": "^13.1.1",
    "fp-ts": "^2.16.5",
    "io-ts": "^2.2.21",
    "io-ts-types": "^0.5.19",
    "monocle-ts": "^2.3.13",
    "newtype-ts": "^0.3.5",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@pagopa/openapi-codegen-ts": "^13.1.0",
    "prettier": "catalog:"
  },
  "peerDependencies": {
    "axios": "^1.6.5"
  },
  "imports": {
    "#package.json": "./package.json"
  }
}
