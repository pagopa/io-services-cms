{
  "name": "@pagopa/io-core-domain",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./value-objects": {
      "import": "./dist/value-objects/index.js",
      "types": "./dist/value-objects/index.d.ts"
    }
  },
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsc",
    "lint": "pnpm lint:check --fix",
    "lint:check": "eslint . --ext .ts --cache",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "neverthrow": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "shx": "catalog:",
    "vitest": "catalog:"
  }
